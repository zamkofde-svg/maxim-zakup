# Caddyfile — reverse proxy с автоматическим HTTPS от Let's Encrypt
# Caddy установлен на хост через apt. Проксирует на docker-контейнер (127.0.0.1:8000).

maxim-rest.tech, www.maxim-rest.tech {
    reverse_proxy 127.0.0.1:8000

    encode gzip zstd

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    log {
        output stdout
        format console
    }
}

# Fallback по IP без HTTPS — для отладки
:80 {
    reverse_proxy 127.0.0.1:8000
}
